# ─── Local development ───
# Railway injects PORT; code prefers it over API_PORT/RUNNER_PORT.
API_PORT=4001
RUNNER_PORT=4101
VITE_API_BASE_URL=http://localhost:4001
RUNNER_BASE_URL=http://localhost:4101
# API_PUBLIC_BASE_URL: handed to the E2B sandbox (MCP gateway) — must be publicly reachable.
API_PUBLIC_BASE_URL=http://localhost:4001
# API_INTERNAL_BASE_URL: runner→API callbacks (task events + sandbox bind). Point at the
# private domain in production; falls back to API_PUBLIC_BASE_URL then localhost.
API_INTERNAL_BASE_URL=http://localhost:4001
RUNNER_MODE=fake
RUN_TIMEOUT_MS=120000

# ─── Postgres (required for production) ───
# DATABASE_URL=postgres://localhost:5432/agent-builder

# ─── API key encryption (required) ───
# 64-character hex (32 bytes). Generate with: openssl rand -hex 32
# Back this up securely — losing it means losing access to all stored API keys.
# LLM_API_KEY_ENCRYPTION_KEY=

# ─── E2B mode (only needed when RUNNER_MODE=e2b) ───
# E2B_API_KEY=
# E2B_TEMPLATE_ID=

# ─── Arcade integration (API service only) ───
# Arcade owns GitHub OAuth/provider credentials; do not expose these to web, runner, E2B, or AgentSpec.
# ARCADE_API_KEY=
# Optional: use only if Arcade support or docs require a non-default API endpoint.
# ARCADE_BASE_URL=
# Arcade project end-user id used for the single-user local demo.
ARCADE_USER_ID=demo-user
# Optional: product-local alias for the Arcade GitHub OAuth provider configured in Arcade Dashboard.
# ARCADE_GITHUB_PROVIDER_ID=agent-builder-github-local

# ─── Runner event auth (optional, enables incremental task events) ───
# Generate with: openssl rand -hex 32
# RUNNER_EVENT_TOKEN=

# ─── Railway production example ───
# PORT is injected by Railway on each service; do not set it manually.
# Web/API service (serves the web SPA same-origin — no VITE_API_BASE_URL needed):
#   RUNNER_BASE_URL=http://agent-builder-runner.railway.internal:4101
#   API_PUBLIC_BASE_URL=https://<web-api-public-domain>
#   API_INTERNAL_BASE_URL=http://<web-api-private-domain>:8080
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#   LLM_API_KEY_ENCRYPTION_KEY=<openssl rand -hex 32, NON-ROTATABLE, back up off-Railway>
#   RUNNER_EVENT_TOKEN=<shared reference variable>
#   ARCADE_API_KEY=<your-arcade-api-key>
#   ARCADE_USER_ID=<your-product-user-id>
#   ARCADE_GITHUB_PROVIDER_ID=agent-builder-github-production
#
# Runner service (deploy RUNNER_MODE=fake first; flip to e2b once the chain is green):
#   RUNNER_MODE=fake
#   RUN_TIMEOUT_MS=120000
#   RUNNER_EVENT_TOKEN=<same shared reference variable as Web/API>
#   E2B_API_KEY=<your-e2b-key>          # only for RUNNER_MODE=e2b
#   E2B_TEMPLATE_ID=<your-template-id>  # only for RUNNER_MODE=e2b
